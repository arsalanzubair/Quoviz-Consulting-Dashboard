# Environment Variables for Quoviz Call Monitor
# Copy this file to .env and fill in the values

# ── Required ────────────────────────────────────────────────
# Password for the admin login page
ADMIN_PASSWORD=your_strong_password_here

# Secret used to sign JWT auth tokens (use a long random string)
SESSION_SECRET=your_long_random_secret_here

# ── Optional ────────────────────────────────────────────────
# If set, visiting /api/auth/magic?token=YOUR_MAGIC_TOKEN auto-logs you in
MAGIC_TOKEN=your_magic_token_here
